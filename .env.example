# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="FastAPI Boilerplate"
APP_VERSION="1.0.0"
ENVIRONMENT=development        # development | production | test
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite — zero-config local development (default)
DATABASE_URL=sqlite:///./todosapp.db

# PostgreSQL — uncomment and fill in for staging / production
# DATABASE_URL=postgresql://user:password@localhost:5432/todosapp
#
# Docker Compose example (see README):
# DATABASE_URL=postgresql://todouser:todopass@db:5432/todosapp

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong key:  openssl rand -hex 32
SECRET_KEY=change-me-in-production-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=20

# ── Rate limiting (requests per minute, per IP) ───────────────────────────────
RATE_LIMIT_PER_MINUTE=60
