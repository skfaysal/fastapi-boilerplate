# Copy this file to .env and fill in real values. Never commit .env.
#   cp .env.example .env

# ── Database ─────────────────────────────────────────────────────────
# Async Postgres URL (note the +asyncpg driver).
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/fastapi_boilerplate

# ── MongoDB (activity log — optional; app boots without it) ──────────
MONGO_URL=mongodb://localhost:27017
MONGO_DB=bookstore

# ── Kafka (event bus in front of the activity log — optional; app boots without it) ──
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Auth / JWT ───────────────────────────────────────────────────────
# REQUIRED. Sign/verify key for JWTs — keep secret, use a different one per
# environment, and never commit the real value. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-to-a-long-random-string

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
